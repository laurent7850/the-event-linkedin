# ============================================
# The Event LinkedIn Automation - Configuration
# ============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git.

# --- Environment ---
NODE_ENV=production
TZ=Europe/Brussels

# --- Domain & URLs ---
DOMAIN=linkedin.the-event.be
APP_URL=https://linkedin.the-event.be
BACKEND_URL=https://linkedin.the-event.be/api

# --- PostgreSQL ---
POSTGRES_USER=theevent
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=theevent_linkedin
POSTGRES_PORT=5432
DATABASE_URL=postgresql://theevent:CHANGE_ME_STRONG_PASSWORD_HERE@postgres:5432/theevent_linkedin

# --- Backend ---
BACKEND_PORT=3001
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS
SESSION_SECRET=CHANGE_ME_RANDOM_64_CHARS
ENCRYPTION_KEY=CHANGE_ME_RANDOM_32_HEX_CHARS
ADMIN_EMAIL=admin@the-event.be
ADMIN_PASSWORD_HASH=

# --- n8n ---
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_STRONG_PASSWORD
N8N_ENCRYPTION_KEY=CHANGE_ME_RANDOM_32_CHARS
N8N_WEBHOOK_URL=https://linkedin.the-event.be/n8n/
N8N_HOST=0.0.0.0
N8N_PROTOCOL=https

# --- OpenRouter ---
OPENROUTER_API_KEY=sk-or-CHANGE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4-20250514
OPENROUTER_TEMPERATURE=0.7
OPENROUTER_MAX_TOKENS=2000
OPENROUTER_TIMEOUT_MS=30000

# --- LinkedIn OAuth ---
LINKEDIN_CLIENT_ID=CHANGE_ME
LINKEDIN_CLIENT_SECRET=CHANGE_ME
LINKEDIN_REDIRECT_URI=https://linkedin.the-event.be/api/auth/linkedin/callback
LINKEDIN_SCOPES=openid,profile,w_member_social

# --- Scheduling ---
WEEKLY_CRON_HOUR=10
WEEKLY_CRON_MINUTE=0
WEEKLY_CRON_DAY=4

# --- Backup ---
BACKUP_ENCRYPTION_KEY=CHANGE_ME_RANDOM_32_CHARS
BACKUP_RETENTION_DAYS=30
BACKUP_CRON=0 2 * * *

# --- SMTP (optional notifications) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@the-event.be
NOTIFICATION_EMAIL=

# --- Traefik ---
ACME_EMAIL=admin@the-event.be

# --- Logging ---
LOG_LEVEL=info
LOG_FORMAT=json
